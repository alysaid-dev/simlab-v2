# Server
NODE_ENV=development
PORT=3000

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# Database (Prisma / PostgreSQL)
DATABASE_URL="postgresql://postgres:kbloIEnCg0r6@localhost:5432/simlab_v2?schema=public"

# Shibboleth
# URL to hit for SP-initiated single logout (served by mod_shib / Nginx auth_request)
SHIBBOLETH_LOGOUT_URL=/Shibboleth.sso/Logout
# Where to redirect the user *after* Shibboleth logout completes
SHIBBOLETH_LOGOUT_RETURN=http://localhost:5173/
# In development you may not have real Shibboleth headers — set this to 1
# to inject a mock user for /api/auth/me.
SHIBBOLETH_DEV_MOCK=0

# =============================================================================
# Notifications
# =============================================================================

# --- Email (Gmail SMTP, port 465 SSL) ---
# Create an App Password at https://myaccount.google.com/apppasswords
# (2FA must be enabled on the Gmail account).
GMAIL_USER=labstatistika.uii@gmail.com
GMAIL_APP_PASSWORD=
# Display name used in the From header
MAIL_FROM_NAME="SIMLAB Laboratorium Statistika UII"

# --- WhatsApp (Fonnte) ---
# Get your device token from https://md.fonnte.com/
FONNTE_TOKEN=

# --- Scheduler ---
# Cron timezone — WIB (Asia/Jakarta)
SCHEDULER_TZ=Asia/Jakarta
# Daily reminder cron expression (default: 08:00 every day)
SCHEDULER_REMINDER_CRON="0 8 * * *"
# Set to 0 to disable the scheduler entirely (useful in dev)
SCHEDULER_ENABLED=1
